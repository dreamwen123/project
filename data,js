// Array of objects representing the study tasks
let studyTasks = [
    {
        id: 1,
        subject: "Mathematics",
        date: "2026-05-12",
        duration: "02:00",
        urgency: 4
    },
    {
        id: 2,
        subject: "Science",
        date: "2026-05-15",
        duration: "01:30",
        urgency: 3
    }
];

// Helper function to find index (Demonstrates a function returning a value used later)
function findTaskIndex(idToFind) {
    let index = -1;
    for (let i = 0; i < studyTasks.length; i++) { // Loop
        if (studyTasks[i].id == idToFind) {       // Comparison
            index = i;
            break;                                // Branching
        }
    }
    return index;
}

// CREATE
function addTask(subject, date, duration, urgency) {
    let newTask = {
        id: Math.floor(Math.random() * 10000) + 1,
        subject: subject,
        date: date,
        duration: duration,
        urgency: urgency
    };
    studyTasks.push(newTask);
}

// DELETE
function deleteTask(idToDelete) {
    // Function call used as a variable/argument
    let foundIndex = findTaskIndex(idToDelete); 
    
    if (foundIndex !== -1) {
        studyTasks.splice(foundIndex, 1);
    }
}

// UPDATE
function updateTask(idToUpdate, newSubject, newDate, newDuration, newUrgency) {
    let foundIndex = findTaskIndex(idToUpdate);
    
    // Logical operator (&&) ensures we only update if the task exists AND data is valid
    if (foundIndex !== -1 && newSubject !== "") {
        studyTasks[foundIndex] = {
            id: idToUpdate,
            subject: newSubject,
            date: newDate,
            duration: newDuration,
            urgency: newUrgency
        };
    }
}